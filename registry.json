      "install": "pip install -e stitch/agent-harness"
    },
    {
      "name": "cli-web-pexels",
      "website": "pexels.com",
      "protocol": "SSR + __NEXT_DATA__ (curl_cffi)",
      "auth": "none",
      "directory": "pexels/agent-harness",
