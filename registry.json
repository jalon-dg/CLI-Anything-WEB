{
  "version": "1.0.0",
  "clis": [
    {
      "name": "cli-web-futbin",
      "website": "futbin.com",
      "protocol": "HTML + JSON API",
      "auth": "none",
      "directory": "futbin/agent-harness",
      "namespace": "cli_web.futbin",
      "commands": ["players search", "players get", "players list", "players compare", "players price-history", "market index", "market popular", "market latest", "market cheapest", "market movers", "market fodder", "sbc list", "sbc get", "evolutions list", "evolutions get", "config set", "config show", "config reset"],
      "install": "pip install -e futbin/agent-harness"
    },
    {
      "name": "cli-web-notebooklm",
      "website": "notebooklm.google.com",
      "protocol": "batchexecute RPC",
      "auth": "google_sso",
